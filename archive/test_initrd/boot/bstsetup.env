PREBUNDLED_APPS="/boot/android/dataFS/"
DATA="/dev/vdb1"
pie_supported_sdk_ver=28
ADD_SYSTEM_PROPS=$PREBUNDLED_APPS/propfiles/additional_system_props/additional_system_prop
if [ `uname -m` == "aarch64" ]; then
    IS_64_BUILD=1
else
    IS_64_BUILD=0
fi

log_echo()
{
    echo "$@" > /dev/kmsg
}

warn_if_error()
{
    # retuning 1 if the calling function has failed, this is used in
    # copy_feature_files function,as we have to remove dir if copy fails
    if [ $? -ne 0 ]; then
        log_echo "<3>WARN: $@"
        return 1
    else
        return 0
    fi
}

die_if_error()
{
    if [ $? -ne 0 ]; then
        log_echo "<2>ERROR: $@"
        exit 1
    else
        return 0
    fi
}

copy_file()
{
    filename=$1
    destination=$2
    log_echo -e  "Copying file $filename to $destination"
    cp -a $filename $destination
    warn_if_error "Error in copying file $filename to location $destination"
}

function migrate_launcher_data_if_required()
{
    if [ ! -f /data/data/com.uncube.launcher3/databases/home.db ]; then
        log_echo -e "Copying home.db"
        chmod 777 /data/data/com.uncube.launcher3/databases/home.db
        chmod 777 /data/data/com.uncube.launcher3/databases/home.db-wal
        chmod 777 /data/data/com.uncube.launcher3/databases/home.db-shm
        chmod 777 /data/data/com.uncube.launcher3/databases/home.db-journal
        copy_file /data/data/com.uncube.launcher3/databases/home.db /data/local/tmp/
        copy_file /data/data/com.uncube.launcher3/databases/home.db-shm /data/local/tmp/
        copy_file /data/data/com.uncube.launcher3/databases/home.db-wal /data/local/tmp/
        chmod 777 /data/local/tmp/home.db
        chmod 777 /data/local/tmp/home.db-wal
        chmod 777 /data/local/tmp/home.db-journal
        chmod 777 /data/local/tmp/home.db-shm
    elif [ -f /data/local/tmp/home.db ]; then
        log_echo -e "Removing home.db from /data/local/tmp/"
        rm -f /data/local/tmp/home.db
        rm -f /data/local/tmp/home.db-wal
        rm -f /data/local/tmp/home.db-shm
        rm -f /data/local/tmp/home.db-journal
    fi
}

function is_greater()
{

    local ver=$1
    local old_ver=$2

    current_major=`echo $ver | cut -d '.' -f 1`
    current_minor=`echo $ver | cut -d '.' -f 2`
    current_patch=`echo $ver | cut -d '.' -f 3`
    current_build=`echo $ver | cut -d '.' -f 4`

    old_major=`echo $old_ver | cut -d '.' -f 1`
    old_minor=`echo $old_ver | cut -d '.' -f 2`
    old_patch=`echo $old_ver | cut -d '.' -f 3`
    old_build=`echo $old_ver | cut -d '.' -f 4`

    is_greater=0

    if [ $current_major -gt $old_major ]; then
        is_greater=1
    elif [ $current_major == $old_major ] && [ $current_minor -gt $old_minor ]; then
        is_greater=1
    elif [ $current_major == $old_major ] && [ $current_minor == $old_minor ] && [ $current_patch -gt $old_patch ]; then
        is_greater=1
    elif [ $current_major == $old_major ] && [ $current_minor == $old_minor ] && [ $current_patch == $old_patch ] && [ $current_build -gt $old_build ]; then
        is_greater=1
    else
        is_greater=0
    fi

    if [ $is_greater -ge 1 ];then
        echo "$ver > $old_ver returning 0"
        return 0
    else
        echo "$old_ver > $ver returning 1"
        return 1
    fi
}

mount_fs()
{
    local type=$1
    local dev=$2
    local path=$3
    local option=$4

    mountpoint -q $path
    if [ $? -eq 0 ]; then
        # already mounted
        return 0
    fi

    echo "Mounting device $dev on $path"

    mount -t $type -o $option $dev $path
    die_if_error "Cannot mount device $dev: mount command failed"
}

mount_data()
{
    mountpoint -q data && return
    mount_fs ext4 $DATA /data rw
}

mount_prebundled_fs()
{
    mkdir -p data/.pb
    chmod 770 data/.pb
    if [ -n "$BST_OEM" ]; then
        oem_in_lower=`echo $BST_OEM | tr '[:upper:]' '[:lower:]'`
        filename="$PREBUNDLED_APPS/bst_appdetails_$oem_in_lower"
        if [ -f $filename ]; then
            log_echo -e  "Use $filename file for OEM $BST_OEM"
            copy_file $filename data/.pb/appdetails
        else
            log_echo -e  "Use bst_appdetails file for OEM $BST_OEM"
            copy_file $PREBUNDLED_APPS/bst_appdetails data/.pb/appdetails
        fi
    fi
    if [ -d $PREBUNDLED_APPS/app ]; then
        copy_file $PREBUNDLED_APPS/app data/.pb/
    fi
}

enable_swapspace()
{
    if [ ! -f /data/swap_space ]; then
        log_echo "Creating swap space"
        dd if=/dev/zero of=/data/swap_space bs=2k count=1M
    fi
    if [ $BST_MEM_SWAP_ENABLED -gt 0 ] && [ -f /data/swap_space ]; then
        log_echo "Enabling swap space"
        mkswap /data/swap_space && swapon /data/swap_space
    fi
}

create_new_propfile()
{
    if [ -n "$BST_GUID" ]; then
        log_echo -e "Updating default system properties for OEM $BST_OEM"
        sed '/ro.product.model=BlueStacks/c ro.product.model=BlueStacks-'"$BST_GUID" system/build.prop > data/.1.prop
        sed '/ro.product.device=AppPlayer/c ro.product.device=AppPlayer-'"$BST_GUID" data/.1.prop > data/.2.prop
        sed '/ro.product.name=BlueStacks/c ro.product.name=BlueStacks-'"$BST_GUID" data/.2.prop > data/.3.prop
    fi
    if [ -f data/.3.prop ]; then
            sed '/ro.build.characteristics=tablet/c ro.build.characteristics=phone' data/.3.prop > data/.bluestacks.prop
            rm -f data/.1.prop data/.2.prop data/.3.prop
    else
            sed '/ro.build.characteristics=tablet/c ro.build.characteristics=phone' system/build.prop > data/.bluestacks.prop
    fi

    echo "" >> data/.bluestacks.prop
    echo "#Misc properties" >> data/.bluestacks.prop
    echo "ro.com.google.gmsversion=7.1_r4" >> data/.bluestacks.prop
    echo "ro.com.google.clientidbase=android-bluestacks" >> data/.bluestacks.prop
    echo "ro.com.google.locationfeatures=1"  >> data/.bluestacks.prop  
    echo "ro.com.google.networklocation=1" >> data/.bluestacks.prop 
    echo "gsm.version.ril-impl=\"BlueStacks RIL(IPC) v1.0\"" >> data/.bluestacks.prop
    echo "gsm.sim.operator.numeric=310260" >> data/.bluestacks.prop
    echo "gsm.sim.operator.alpha=BlueStacks" >> data/.bluestacks.prop
    echo "gsm.sim.operator.iso-country=us" >> data/.bluestacks.prop
    echo "gsm.sim.state=READY" >> data/.bluestacks.prop
    echo "gsm.current.phone-type=1" >> data/.bluestacks.prop
    echo "gsm.operator.alpha=BlueStacks" >> data/.bluestacks.prop
    echo "gsm.operator.numeric=310260" >> data/.bluestacks.prop
    echo "gsm.operator.iso-country=us" >> data/.bluestacks.prop
    echo "gsm.operator.isroaming=false" >> data/.bluestacks.prop
    echo "gsm.network.type=LTE" >> data/.bluestacks.prop
    echo "gsm.sim.bstserial=8901260" >> data/.bluestacks.prop
    echo "ro.sf.lcd_density=160" >> data/.bluestacks.prop
    #echo "bst.config.densityReport=2.0" >> data/.bluestacks.prop
    #echo "bst.config.widthReport=720" >> data/.bluestacks.prop
    #echo "bst.config.heightReportAdjust=1280" >> data/.bluestacks.prop
    #echo "bst.config.heightReport=1280" >> data/.bluestacks.prop
    #echo "bst.config.scaledDensityReport=2.0" >> data/.bluestacks.prop
    #echo "bst.config.xdpiReport=290.327" >> data/.bluestacks.prop
    #echo "bst.config.ydpiReport=290.913" >> data/.bluestacks.prop
}

# This function is to update the /data/.propfile (aka /system/build.prop) based on the /data/.bluestacks.prop file created via update_propfile()
# This is to keep the build.prop inline with our propfile.
# Copying data/.bluestacks.prop to data/.propfile, and we redirect /system/build.prop to /data/.propfile from kernel
# Copying data/.bluestacks.prop to data/.abipropfile, after modifying abi values
# and we redirect /system/build.prop to /data/.abipropfile for arm apps from kernel
# Bug 4665: com.lanjingren.ivwen crashes on launch. Similar app: com.appshenqi.cilikanpian
update_build_prop()
{
    # modified build.prop file didn't exist currently, create it using .bluestacks.prop file.
    if [ ! -f "data/.bluestacks.prop" ]; then
        retval=$?
        log_echo -e "bluestacks propfile not present, returning $retval"
        return $retval
    fi

    log_echo -e "Updating build.prop files in data"
    sed '/# Misc Properties/,$ d' data/.bluestacks.prop > data/.1.prop
    sed '$ d' data/.1.prop > data/.2.prop
    copy_file data/.2.prop data/.propfile
    if [ $IS_64_BUILD -eq 1 ];then
        sed '/ro.product.cpu.abilist=x86/c ro.product.cpu.abilist=arm64-v8a,armeabi-v7a,armeabi' data/.2.prop > data/.3.prop
        sed '/ro.product.cpu.abilist32=x86/c ro.product.cpu.abilist32=armeabi-v7a,armeabi' data/.3.prop > data/.4.prop
        sed '/ro.product.cpu.abilist64=x86/c ro.product.cpu.abilist64=arm64-v8a' data/.4.prop > data/.5.prop
        sed '/ro.product.cpu.abi=x86/c ro.product.cpu.abi=arm64-v8a' data/.5.prop > data/.6.prop
        # copying arm modified prop file as /data/.abipropfile
        copy_file data/.6.prop data/.abipropfile

        rm -f data/.1.prop data/.2.prop data/.3.prop data/.4.prop data/.5.prop data/.6.prop

    else
        sed '/ro.product.cpu.abilist=x86/c ro.product.cpu.abilist=armeabi-v7a,armeabi' data/.2.prop > data/.3.prop
        sed '/ro.product.cpu.abilist32=x86/c ro.product.cpu.abilist32=armeabi-v7a,armeabi' data/.3.prop > data/.4.prop
        sed '/ro.product.cpu.abi=x86/c ro.product.cpu.abi=armeabi-v7a' data/.4.prop > data/.5.prop
        # copying arm modified prop file as /data/.abipropfile
        copy_file data/.5.prop data/.abipropfile

        rm -f data/.1.prop data/.2.prop data/.3.prop data/.4.prop data/.5.prop
    fi
}

# This function is to create and update /data/.dfprop (copy of /default.prop) based on the /data/.bluestacks.prop
# This file masks default values of properties like ro.secure=0, ro.debuggable=1, etc to actual device values.
# Case 13868: App like com.aniplex.fategrandorder reads this file and gets incorrect values from original file read which
# point towards rooted/emulated environment.
# Also, making a copy of actual default.prop under /data/.def.prop to modify ro.bootimage.build.fingerprint to remove
# test-keys string and replace it with ro.build.fingerprint having relevant device fingerprint values.
update_default_build_prop()
{
    if [ ! -f "data/.bluestacks.prop" ]; then
        retval=$?
        log_echo -e "bluestacks propfile not present, returning $retval"
        return $retval
    fi

    log_echo -e "Updating default propfile"

    fingerprint=`grep -i "ro\.system\.build\.fingerprint" /data/.bluestacks.prop | cut -d "=" -f 2`

    sed "/ro.bootimage.build.fingerprint=*/c ro.bootimage.build.fingerprint=${fingerprint}" /default.prop > data/.1.prop
    sed "/ro.bootimage.build.fingerprint=*/c ro.bootimage.build.fingerprint=${fingerprint}" /default.prop > data/.def.prop
    sed '/ro.secure=0/c ro.secure=1' data/.1.prop > data/.2.prop
    sed '/ro.debuggable=1/c ro.debuggable=0' data/.2.prop > data/.3.prop
    sed '/ro.arch=x86/c ro.arch=' data/.3.prop > data/.dfprop

    rm -f data/.1.prop data/.2.prop data/.3.prop
}

update_default_vendor_prop()
{
    if [ ! -f "data/.bluestacks.prop" ]; then
        retval=$?
        log_echo -e "bluestacks propfile not present, returning $retval"
        return $retval
    fi

    log_echo -e "Updating vendor propfile"

    fingerprint=`grep -i "ro\.system\.build\.fingerprint" /data/.bluestacks.prop | cut -d "=" -f 2`

    security_patch=`grep -i "ro\.build\.version\.security_patch" /data/.bluestacks.prop | cut -d "=" -f 2`
    board=`grep -i "ro\.product\.board" /data/.bluestacks.prop | cut -d "=" -f 2`
    platform=`grep -i "ro\.board\.platform" /data/.bluestacks.prop | cut -d "=" -f 2`
    manufacturer=`grep -i "ro\.product\.manufacturer" /data/.bluestacks.prop | cut -d "=" -f 2`
    model=`grep -i "ro\.product\.model" /data/.bluestacks.prop | cut -d "=" -f 2`
    brand=`grep -i "ro\.product\.brand" /data/.bluestacks.prop | cut -d "=" -f 2`
    name=`grep -i "ro\.product\.name" /data/.bluestacks.prop | cut -d "=" -f 2`
    device=`grep -i "ro\.product\.device" /data/.bluestacks.prop | cut -d "=" -f 2`
    sed "/ro.vendor.build.fingerprint=*/c ro.vendor.build.fingerprint=${fingerprint}" /vendor/build.prop > data/.vendor.prop


    sed -i "/ro.bootimage.build.fingerprint.*/c ro.bootimage.build.fingerprint=${fingerprint}"  data/.vendor.prop
    date=`grep -i "ro\.build\.date=" /data/.bluestacks.prop | cut -d "=" -f 2`
    utc=`grep -i "ro\.build\.date\.utc=" /data/.bluestacks.prop | cut -d "=" -f 2`
    buildid=`grep -i "ro\.build\.id" /data/.bluestacks.prop | cut -d "=" -f 2`
    buildtags=`grep -i "ro\.build\.tags" /data/.bluestacks.prop | cut -d "=" -f 2`
    builtypes=`grep -i "ro\.build\.type" /data/.bluestacks.prop | cut -d "=" -f 2`
    versionInc=`grep -i "ro\.build\.version\.incremental" /data/.bluestacks.prop | cut -d "=" -f 2`
    sed -i "/ro.vendor.build.date.utc=*/c ro.vendor.build.date.utc=${utc}"  data/.vendor.prop
    sed -i "/ro.bootimage.build.date.utc=*/c ro.bootimage.build.date.utc=${utc}"  data/.vendor.prop
    sed -i "s/ro.vendor.build.date=.*/ro.vendor.build.date=${date}/" /data/.vendor.prop
    sed -i "s/ro.bootimage.build.date=.*/ro.bootimage.build.date=${date}/" /data/.vendor.prop
    sed -i "s/ro.vendor.build.id.*/ro.vendor.build.id=${buildid}/" data/.vendor.prop
    sed -i "s/ro.vendor.build.tags.*/ro.vendor.build.tags=${buildtags}/" data/.vendor.prop
    sed -i "s/ro.vendor.build.type.*/ro.vendor.build.type=${builtypes}/" data/.vendor.prop
    sed -i "s/ro.vendor.build.version.incremental.*/ro.vendor.build.version.incremental=${versionInc}/" data/.vendor.prop

    sed -i "s/ro.vendor.build.security_patch.*/ro.vendor.build.security_patch=${security_patch}/" data/.vendor.prop
    sed -i "s/ro.product.board.*/ro.product.board=${board}/" data/.vendor.prop
    sed -i "s/ro.board.platform.*/ro.board.platform=${platform}/" data/.vendor.prop
    sed -i "s/ro.product.vendor.manufacturer.*/ro.product.vendor.manufacturer=${manufacturer}/" data/.vendor.prop
    sed -i "s/ro.product.vendor.model.*/ro.product.vendor.model=${model}/" data/.vendor.prop
    sed -i "s/ro.product.vendor.brand.*/ro.product.vendor.brand=${brand}/" data/.vendor.prop
    sed -i "s/ro.product.vendor.name.*/ro.product.vendor.name=${name}/" data/.vendor.prop
    sed -i "s/ro.product.vendor.device.*/ro.product.vendor.device=${device}/" data/.vendor.prop
}

update_additional_system_prop()
{
    log_echo -e "update_additional_system_prop IN"
    if [ ! -f "data/.bluestacks.prop" ]; then
        retval=$?
        log_echo -e "bluestacks propfile not present, returning $retval"
        return $retval
    fi

    if [ ! -s /data/.additional_system.prop ]; then
        if [ -f $ADD_SYSTEM_PROPS.$DEVICE_CARRIER_CODE ]; then
            copy_file $ADD_SYSTEM_PROPS.$DEVICE_CARRIER_CODE data/.additional_system.prop
        else
            log_echo -e "$ADD_SYSTEM_PROPS.$DEVICE_CARRIER_CODE file not present, Hence copying default"
            copy_file $ADD_SYSTEM_PROPS data/.additional_system.prop
        fi
    else
        bluestacks_prop_fingerprint=`grep -i "ro\.system\.build\.fingerprint" /data/.bluestacks.prop | cut -d "=" -f 2`
        additional_system_fingerprint=`grep -i "ro\.system_ext\.build\.fingerprint" /data/.additional_system.prop | cut -d "=" -f 2`
        if [ "$bluestacks_prop_fingerprint" != "$additional_system_fingerprint" ]; then
            log_echo -e "Updating additional systems's props"
            manufacturer=`grep -i "ro\.product\.manufacturer" /data/.bluestacks.prop | cut -d "=" -f 2`
            model=`grep -i "ro\.product\.model" /data/.bluestacks.prop | cut -d "=" -f 2`
            brand=`grep -i "ro\.product\.brand" /data/.bluestacks.prop | cut -d "=" -f 2`
            name=`grep -i "ro\.product\.name" /data/.bluestacks.prop | cut -d "=" -f 2`
            device=`grep -i "ro\.product\.device" /data/.bluestacks.prop | cut -d "=" -f 2`
            sync_type='system_ext product odm vendor_dlkm system_dlkm odm_dlkm'

            for type in ${sync_type}
            do
                sed -i "/ro.${type}.build.fingerprint.*/c ro.${type}.build.fingerprint=${bluestacks_prop_fingerprint}" data/.additional_system.prop
                sed -i "s/ro.product.${type}.brand.*/ro.product.${type}.brand=${brand}/" data/.additional_system.prop
                sed -i "s/ro.product.${type}.device.*/ro.product.${type}.device=${device}/" data/.additional_system.prop
                sed -i "s/ro.product.${type}.manufacturer.*/ro.product.${type}.manufacturer=${manufacturer}/" data/.additional_system.prop
                sed -i "s/ro.product.${type}.model.*/ro.product.${type}.model=${model}/" data/.additional_system.prop
                sed -i "s/ro.product.${type}.name.*/ro.product.${type}.name=${name}/" data/.additional_system.prop
            done
        fi
    fi
}

# This function is called to update the propfile when BST_DEVICE_COUNTRY_CODE ,BST_DEVICE_CARRIER_CODE and BST_DEVICE_PROFILE_CODE are given.
update_propfile()
{
    DEVICE_CARRIER_CODE=$BST_DEVICE_PROFILE_CODE
    if [ -z "$BST_DEVICE_COUNTRY_CODE" ]; then
	log_echo -e " BST_DEVICE_COUNTRY_CODE not defined : use US as default"
	BST_DEVICE_COUNTRY_CODE=$US
    fi
    if [ -z "$BST_DEVICE_PROFILE_CODE" ]; then
        log_echo -e " BST_DEVICE_PROFILE_CODE not defined : use SM-G998B as default"
        BST_DEVICE_PROFILE_CODE="stou"
    fi
    if [ ! -d $PREBUNDLED_APPS/propfiles/$BST_DEVICE_COUNTRY_CODE ]; then
#        BST_DEVICE_COUNTRY_CODE=${COUNTRIES["US"]}
        log_echo -e "in update_propfile : no folder found for $BST_DEVICE_COUNTRY_CODE, so using US as fallback"
        BST_DEVICE_COUNTRY_CODE=$US
    fi
# Retrievig the value associated with $BST_DEVICE_PROFILE_CODE
# For eg - if BST_DEVICE_PROFILE_CODE is ofpn then desired vaue is ONEPLUS5

    eval BST_DEVICE_PROFILE_CODE=\$$BST_DEVICE_PROFILE_CODE
    if [ -z "$BST_DEVICE_CARRIER_CODE" ]; then
        log_echo -e " BST_DEVICE_CARRIER_CODE not defined : using $BST_DEVICE_COUNTRY_CODE as substring for BST_DEVICE_CARRIER_CODE to use the default carrier for a particular country"
        BST_DEVICE_CARRIER_CODE="$BST_DEVICE_COUNTRY_CODE"
    else
        eval BST_DEVICE_CARRIER_CODE=\$$BST_DEVICE_CARRIER_CODE
    fi 

# handling cases where junk was passed as BST_DEVICE_PROFILE_CODE or BST_DEVICE_CARRIER_CODE 
# replacing junk with the default values 
# NOTE THAT - here we replace directly the referenced values instead of the keys(as we did above)
    if [ -z "$BST_DEVICE_PROFILE_CODE" ]; then
        log_echo -e " BST_DEVICE_PROFILE_CODE not defined : use SM-G998B as default"
        BST_DEVICE_PROFILE_CODE="stou"
    fi
    if [ -z "$BST_DEVICE_CARRIER_CODE" ]; then
        log_echo -e " BST_DEVICE_CARRIER_CODE not defined : use BST_DEVICE_COUNTRY_CODE: $BST_DEVICE_COUNTRY_CODE as default"
        BST_DEVICE_CARRIER_CODE="$BST_DEVICE_COUNTRY_CODE"
    fi

    if [ -d $PREBUNDLED_APPS/propfiles/$BST_DEVICE_COUNTRY_CODE ]; then
        sdk=`grep -i ro.build.version.sdk $PREBUNDLED_APPS/bluestacks.prop.orig.$US | cut -d = -f 2`
        log_echo -e "update_propfiles : newer sdk is $sdk ,BST_DEVICE_COUNTRY_CODE is $BST_DEVICE_COUNTRY_CODE, BST_DEVICE_CARRIER_CODE is $BST_DEVICE_CARRIER_CODE and BST_DEVICE_PROFILE_CODE is $BST_DEVICE_PROFILE_CODE"
        propfile=`ls $PREBUNDLED_APPS/propfiles/$BST_DEVICE_COUNTRY_CODE/ | grep -iw $BST_DEVICE_PROFILE_CODE`
        if [ -z "$propfile" ]; then
            # use newer profiles if its a fresh install
            log_echo -e "in update_propfile : no file found for $BST_DEVICE_PROFILE_CODE, so using random device file(except s2,s3,note*) as fallback, matching carrier:$BST_DEVICE_CARRIER_CODE"
            totalfiles=`ls $PREBUNDLED_APPS/propfiles/$BST_DEVICE_COUNTRY_CODE | grep -i $BST_DEVICE_CARRIER_CODE | wc -l`
            RANDOM=`date '+%s'`
            x=$RANDOM
            y=$(($x%$totalfiles+1))
            log_echo -e "RANDOM : $x , total eligible files : $totalfiles and final_rand used : $y"
            propfile=`ls $PREBUNDLED_APPS/propfiles/$BST_DEVICE_COUNTRY_CODE/ | grep -i $BST_DEVICE_CARRIER_CODE | sed -n "${y}p"`
            if [ -z "$propfile" ]; then
                # no device profile with our BST_DEVICE_CARRIER_CODE, check for any valid BST_DEVICE_CARRIER_CODE - using $BST_DEVICE_COUNTRY_CODE to find default carrier propfile
                log_echo -e "in update_propfile : no file found for $BST_DEVICE_CARRIER_CODE, so using default carrier: $BST_DEVICE_COUNTRY_CODE as fallback"
                totalfiles=`ls $PREBUNDLED_APPS/propfiles/$BST_DEVICE_COUNTRY_CODE | grep -i $BST_DEVICE_COUNTRY_CODE | wc -l`
                RANDOM=`date '+%s'`
                x=$RANDOM
                y=$(($x%$totalfiles+1))
                log_echo -e "RANDOM : $x , total eligible files : $totalfiles and final_rand used : $y"
                final_propfile=`ls $PREBUNDLED_APPS/propfiles/$BST_DEVICE_COUNTRY_CODE/ | grep -i $BST_DEVICE_COUNTRY_CODE | sed -n "${y}p"`
                if [ -n "$final_propfile" ]; then
                    log_echo -e "Updating via propfile: $final_propfile"
                    copy_file $PREBUNDLED_APPS/propfiles/$BST_DEVICE_COUNTRY_CODE/$final_propfile data/.bluestacks.prop
                else
                    log_echo -e "in update_propfile : no file found for default carrier: $BST_DEVICE_COUNTRY_CODE as fallback - so using any found file"
                    totalfiles=`ls $PREBUNDLED_APPS/propfiles/$BST_DEVICE_COUNTRY_CODE | wc -l`
                    RANDOM=`date '+%s'`
                    x=$RANDOM
                    y=$(($x%$totalfiles+1))
                    log_echo -e "RANDOM : $x , total eligible files : $totalfiles and final_rand used : $y"
                    final_propfile=`ls $PREBUNDLED_APPS/propfiles/$BST_DEVICE_COUNTRY_CODE/ | sed -n "${y}p"`
                    if [ -n "$final_propfile" ]; then
                        log_echo -e "Updating via propfile: $final_propfile"
                        copy_file $PREBUNDLED_APPS/propfiles/$BST_DEVICE_COUNTRY_CODE/$final_propfile data/.bluestacks.prop
                    else
                        log_echo -e "in update_propfile : no suitable file found in $BST_DEVICE_COUNTRY_CODE, so creating new propfile as final fallback"
                        create_new_propfile
                    fi
                fi
            else
                log_echo -e "Updating default system properties using propfile $propfile"
                copy_file $PREBUNDLED_APPS/propfiles/$BST_DEVICE_COUNTRY_CODE/$propfile data/.bluestacks.prop
            fi
        else
            log_echo -e "Found propfiles confirming to BST_DEVICE_PROFILE_CODE: $BST_DEVICE_PROFILE_CODE"
            log_echo -e "Looking to update default system properties using propfile $propfile and BST_DEVICE_CARRIER_CODE: $BST_DEVICE_CARRIER_CODE"
            final_propfile=`ls $PREBUNDLED_APPS/propfiles/$BST_DEVICE_COUNTRY_CODE/ | grep -iw $BST_DEVICE_PROFILE_CODE | grep -i $BST_DEVICE_CARRIER_CODE`
            if [ -n "$final_propfile" ]; then
                log_echo -e "Updating via propfile: $final_propfile"
                copy_file $PREBUNDLED_APPS/propfiles/$BST_DEVICE_COUNTRY_CODE/$final_propfile data/.bluestacks.prop
            else
                log_echo -e "did not find a propfile for selector: $BST_DEVICE_CARRIER_CODE, trying default selector which ends with $BST_DEVICE_COUNTRY_CODE"
                final_propfile=`ls $PREBUNDLED_APPS/propfiles/$BST_DEVICE_COUNTRY_CODE/ | grep -iw $BST_DEVICE_PROFILE_CODE | grep -i $BST_DEVICE_COUNTRY_CODE`
                if [ -n "$final_propfile" ]; then
                    log_echo -e "Updating via propfile: $final_propfile"
                    copy_file $PREBUNDLED_APPS/propfiles/$BST_DEVICE_COUNTRY_CODE/$final_propfile data/.bluestacks.prop
                else 
                    log_echo -e "found no propfile even for default selector(by design it should never happen) - picking any random file of BST_DEVICE_PROFILE_CODE: $BST_DEVICE_PROFILE_CODE"
                    totalfiles=`ls $PREBUNDLED_APPS/propfiles/$BST_DEVICE_COUNTRY_CODE | grep -iw $BST_DEVICE_PROFILE_CODE | wc -l`
                    RANDOM=`date '+%s'`
                    x=$RANDOM
                    y=$(($x%$totalfiles+1))
                    log_echo -e "RANDOM : $x , total eligible files : $totalfiles and final_rand used : $y"
                    final_propfile=`ls $PREBUNDLED_APPS/propfiles/$BST_DEVICE_COUNTRY_CODE/ | grep -iw $BST_DEVICE_PROFILE_CODE | sed -n "${y}p"`
                    if [ -n "$final_propfile" ]; then
                        log_echo -e "Updating via propfile: $final_propfile"
                        copy_file $PREBUNDLED_APPS/propfiles/$BST_DEVICE_COUNTRY_CODE/$final_propfile data/.bluestacks.prop
                    else
                        # Probability of this event = 0
                        log_echo -e "in update_propfile : no suitable file found in $BST_DEVICE_COUNTRY_CODE, so creating new propfile as final fallback"
                        create_new_propfile
                    fi
                fi
            fi
        fi
    else
        log_echo -e "in update_propfile : no folder found for $BST_DEVICE_COUNTRY_CODE, so create new propfile as fallback"
        create_new_propfile
    fi
}

# This will be called only once and that is also during the fresh installation case only
remove_extra_apps()
{
    # Since, appdetails file contain the correct information about the apps required 
    # as per the OEM requirement, use that file to check if copied app requires for
    # this installation or not
    log_echo -e "Removing any data app file that is not needed for this OEM $BST_OEM"
    file="data/.pb/appdetails"
    if [ -f $file ]; then
        for i in `ls data/app/`
        do
            grep -q ";$i.apk" $file
            if [ "$?" -eq "1" ]; then
                log_echo -e "Removing $i file for OEM $BST_OEM"
                rm -rf data/app/$i
            fi
        done 
    else
        # As there is no appdetails file present, no data App apk is required for this
        # OEM, so removing the whole data/app folder
        log_echo -e "Removing whole data/app folder for OEM $BST_OEM"
        rm -rf data/app/
    fi
}

# This will be called only once and that is also during the fresh installation case only
copy_prebundled_fs_files()
{
	if [ -d $PREBUNDLED_APPS/downloads/ ]; then
        log_echo -e "Copying prebundled FS files."
        if [ -f $PREBUNDLED_APPS/downloads/.xb/busybox ]; then
            rm -rf data/downloads/.xb
            mkdir -p data/downloads/.xb
            die_if_error "Cannot create directory /data/downloads/.xb"
            chown 1000 data/downloads/.xb
            chgrp 1000 data/downloads/.xb
            chmod 775 data/downloads/.xb
            copy_file $PREBUNDLED_APPS/downloads/.xb/busybox data/downloads/.xb/
        fi
        cp -a $PREBUNDLED_APPS/* data/
        die_if_error "Cannot copy prebundledapps content to $DATA"
        mkdir -p /data/downloads/.tmp
        warn_if_error "Cannot create directory /data/downloads/.tmp"
        chown 1000 /data/downloads/.tmp
        chgrp 1000 /data/downloads/.tmp
        chmod 777 /data/downloads/.tmp
        rm -rf data/propfiles/
        rm -f data/bst_appdetails*
        rm -f data/appdetails*
        rm -rf data/permissions
        rm -rf data/system-app
        rm -rf data/system-priv-app
        rm -rf data/system-lib
        rm -f data/bluestacks.prop.orig.*
	fi
    # Remove all those extra apps from data/app which are present in PrebundleFS but 
    # not required as per the OEM. 
    remove_extra_apps
}

# Called whenever an upgrade occur irrespective of whether it is from N to N or from KK to N

upgrade_prebundled_fs_files()
{
    # Upgrade logic for the prop files, use the older device profile if it exists, else create a new one and use that
    sdk=""
    # checks for cpuabi values, if upgrading from 32 bit to 64 bit N to N, K to N handled from update_propfile_to_nougat 
    cpuabi=""
    changecpuabi=0

    if [ -s data/.bluestacks.prop ]; then
        sdk=`grep -i ro.build.version.sdk data/.bluestacks.prop | cut -d = -f 2`
    elif [ -s data/bluestacks.prop ]; then
        sdk=`grep -i ro.build.version.sdk data/bluestacks.prop | cut -d = -f 2`
    fi

    log_echo -e "current sdk version $sdk for oem $BST_OEM"

    # Also, remove older stale 3rd party system apk or jar/so files (if there is any) for this case as they may no 
    # longer work with the latest version. 
    log_echo -e "Removing any staled apks/library files present in special folder(downloads and priv-downloads)"
    if [ -d data/downloads/ ]; then
        log_echo -e "downloads directory already exists in DataFS -- removing it"
        rm -rf data/downloads/*
        rm -rf data/downloads/.oh
    else
        log_echo -e "downloads directory didn't exist currently....creating it"
        mkdir -p data/downloads
        chown 1000 data/downloads
        chgrp 1000 data/downloads
        chmod 775 data/downloads
    fi

    if [ -d data/priv-downloads/ ]; then
        log_echo -e "priv-downloads directory already exists in DataFS -- removing it"
        # Deleting all apps except Samsung and one store in case we upgrade to a build which does not prebundle these apps
        find data/priv-downloads/ ! -name ".*" -mindepth 1 -maxdepth 1 ! -iname "samsung*" ! -iname "onestore*" -exec rm -rf {} + 2>/dev/null
    else
        log_echo -e "priv-downloads directory didn't exist currently....creating it"
        mkdir -p data/priv-downloads
        chown 1000 data/priv-downloads
        chgrp 1000 data/priv-downloads
        chmod 775 data/priv-downloads
    fi

    copy_file "$PREBUNDLED_APPS/downloads/*" "data/downloads"
    copy_file "$PREBUNDLED_APPS/downloads/.*" "data/downloads/"
    copy_file "$PREBUNDLED_APPS/priv-downloads/*" "data/priv-downloads"

    if [ -s data/.bluestacks.prop ]; then
        cpuabi=`grep -i ro.product.cpu.abi= data/.bluestacks.prop | cut -d = -f 2`
    fi

    log_echo -e "Checking correctness of CPU ABIs"
    changecpuabi=0

    # android is 64 bit N build, but if cpuabi is still x86, build will not boot, fixing that
    if [ "$cpuabi" = "x86" ] && [ $IS_64_BUILD -eq 1 ]; then
        changecpuabi=1
    fi

    if [ $changecpuabi -gt 0 ]; then
        log_echo -e "N32 to N64 upgrade"
        update_propfile
    fi

    # Removing this file as it is no longer used for any scenarios from ICS onwards.
    rm -f data/bluestacks.prop
}

prepare_bst_filesystems()
{
    mountpoint -q data
    if [ "$?" -ne "0" ]; then
        log_echo -e "This is the first time dataFS is mounting, formatting it now."
        /system/bin/mke2fs -T ext4 -m 1 -L Data -O ^dir_index,^flex_bg,^huge_file,^dir_nlink,^extra_isize -F $DATA
        die_if_error "Cannot format $DATA as ext4 FS"
        log_echo -e "Mounting DataFS now."
        mount_data
		die_if_error "Cannot mount $DATA"
    else
        log_echo -e "DataFS is already mounted."
    fi

    if [ -f data/done.txt ]; then
        log_echo -e "Prebundled apps are already copied. Checking if they are of latest version or not."
    else
        log_echo -e "Mounting prebundled appFS."
        mount_prebundled_fs
        log_echo -e "Copy prebundled apps into dataFS."
        copy_prebundled_fs_files
        log_echo -e "Updating prop files."
        update_propfile
        echo "$BST_VERSION" > data/done.txt
        echo "Done" > data/$BST_VERSION
        echo "Done" > data/.pb/$BST_VERSION
        blk=`basename $DATA`
        log_echo -e "Removing some of the default feature values from dataFS /dev/block/$blk"
        /system/bin/tune2fs -O ^dir_index,^huge_file,^dir_nlink,^extra_isize /dev/block/$blk
        sync
        bstsyncfs $DATA
    fi

    migrate_launcher_data_if_required

    if [ -n "$BST_VERSION" ]; then
        if [ -s data/$BST_VERSION ]; then
            log_echo -e "Prebundled apps are latest one."
            log_echo -e "Checking if google apps are present in data/priv-downloads."
            if [ ! -f /data/priv-downloads/com.google.android.gms/base.apk ]; then
                log_echo -e "Google apps not present in data/priv-downloads"
                mount_prebundled_fs
                upgrade_prebundled_fs_files
            fi
        else
            if [ -s data/.pb/$BST_VERSION ]; then
                log_echo -e "Prebundled apps are latest one."
            else
                blk=`basename $DATA`
                log_echo -e "Removing some of the default feature values from dataFS /dev/block/$blk"
                /system/bin/tune2fs -O ^dir_index,^huge_file,^dir_nlink,^extra_isize /dev/block/$blk
                log_echo -e "Upgrading dataFS with latest prebundled apps."
                mount_prebundled_fs
                upgrade_prebundled_fs_files
            fi
            echo "Done" > data/$BST_VERSION
            # BS4-4609 Apps still not searchable on GP when upgraded to 4.110.0 build but available on fresh 4.110.0 install
            # Check the contents of done.txt 
            # If the val is "Done" that means DG (DroidGuard) changes are not present in the build 
            # so in this case we will clear the google apps data by creating the .uninstall_staleapps.txt file which will trigger clear apps data code in postupgrade script.
            # Else if version is present that means we are upgrading from a build which already have Droid Guard changes
            # so doing nothing in that case
            val=`cat data/done.txt`
            uninstall_staleapps=0
            if [ $val == "Done" ]; then
                # 4.110.0.1043 means build number can be equal to this or older than this.
                # as in old builds content of done.txt does not have relevant info.
                echo "4.110.0.1043" > data/.pb/upgraded_from
                log_echo -e "Creating .uninstall_staleapps"
                uninstall_staleapps=1
            else
                echo "$val" > data/.pb/upgraded_from
                is_greater "4.130.1.0000" $val
                if [ "$?" -eq 0 ];then
                    log_echo -e "Creating .uninstall_staleapps version in done.txt $val"
                    uninstall_staleapps=1
                fi
            fi
            if [ $uninstall_staleapps -gt 0 ]; then
                echo "Done .. previous done.txt content is $val" > data/downloads/.uninstall_staleapps.txt
            fi
            log_echo -e "creating first_boot_after_upgrade file"
            echo "" > data/.pb/first_boot_after_upgrade

            # creating a new marker file, this is used in PackageManagerService.java
            # to copy system apps libs on first boot after upgrade
            log_echo -e "creating first_boot_after_upgrade_for_pm file"
            echo "" > data/downloads/.first_boot_after_upgrade_for_pm

            echo "$BST_VERSION" > data/done.txt
            sync
            bstsyncfs $DATA
        fi
    else
        log_echo -e "Version information is not available for OEM $BST_OEM."
    fi
    
    # If because of some error (like required prop file is not present in prebundle FS) prop file is 
    # still not present at desired location, give it one more try. Ideally, this shouldn't be the case.
    if [ ! -s "data/.bluestacks.prop" ]; then
        update_propfile
    fi

    # updating the build.prop file based on bluestacks property file.
    if [ ! -s "data/.abipropfile" ] || [ ! -s "data/.propfile" ]; then
        log_echo -e "Upgrading build.prop based on latest bluestacks property file."
        update_build_prop
    fi

    # updating the default.prop file based on bluestacks property file.
    if [ ! -s "data/.dfprop" ] || [ ! -s "data/.def.prop" ]; then
        log_echo -e "Updating default.prop based on latest bluestacks property file."
        update_default_build_prop
    fi

    # updating  /data/.vendor.prop file based on /vendor/build.prop file.
    current_sdk_ver=`grep -i ro.build.version.sdk data/.bluestacks.prop | cut -d = -f 2`
    if [ $current_sdk_ver -ge $pie_supported_sdk_ver ]; then
        if [ ! -s "data/.vendor.prop" ]; then
            log_echo -e "Updating vendor.prop based on /vendor/build.prop file."
            update_default_vendor_prop
        else
            bluestacks_prop_fingerprint=`grep -i "ro\.build\.fingerprint" /data/.bluestacks.prop | cut -d "=" -f 2`
            vendor_prop_fingerprint=`grep -i "ro\.vendor\.build\.fingerprint" /data/.vendor.prop | cut -d "=" -f 2`
            if [ "$bluestacks_prop_fingerprint" != "$vendor_prop_fingerprint" ]; then
                update_default_vendor_prop
            fi
        fi
    fi
    update_additional_system_prop

    # making sure that latest conf values are used within android
    if [ -s "/.bstconf.prop" ]; then
        rm -f "data/.bstconf.prop"
        copy_file "/.bstconf.prop" "data/.bstconf.prop"
        rm -f "/.bstconf.prop"
    fi
}

set_propfile_permissions()
{
    if [ -s /data/.propfile ]; then
        log_echo -e "changing permission of .propfile"
        chown 1000 /data/.propfile
        chgrp 1000 /data/.propfile
        chmod 644 /data/.propfile
    fi

    if [ -s /data/.abipropfile ]; then
        log_echo -e "changing permission of .abipropfile"
        chown 1000 /data/.abipropfile
        chgrp 1000 /data/.abipropfile
        chmod 644 /data/.abipropfile
    fi

    if [ -s /data/.bluestacks.prop ]; then
        log_echo -e "changing permission of .bluestacks.prop"
        chown 1000 /data/.bluestacks.prop
        chgrp 1000 /data/.bluestacks.prop
        chmod 644 /data/.bluestacks.prop
    fi

    if [ -f /data/.def.prop ]; then
        log_echo -e "changing permission of .def.prop"
        chown 1000 /data/.def.prop
        chgrp 1000 /data/.def.prop
        chmod 644 /data/.def.prop
    fi

    current_sdk_ver=`grep -i ro.build.version.sdk data/.bluestacks.prop | cut -d = -f 2`
    if [ $current_sdk_ver -ge $pie_supported_sdk_ver ] && [ -s /data/.vendor.prop ]; then
        log_echo -e "changing permission of .vendor.prop"
        chown 1000 /data/.vendor.prop
        chgrp 1000 /data/.vendor.prop
        chmod 644 /data/.vendor.prop
    fi

    if [ -f /data/.dfprop ]; then
        log_echo -e "changing permission of .dfprop"
        chown 1000 /data/.dfprop
        chgrp 1000 /data/.dfprop
        chmod 644 /data/.dfprop
    fi

    if [ -s /data/.bstconf.prop ]; then
        log_echo -e "changing permission of .bstconf.prop"
        chown 1000 /data/.bstconf.prop
        chgrp 1000 /data/.bstconf.prop
        chmod 644 /data/.bstconf.prop
    fi

    if [ -s /data/.additional_system.prop ]; then
        log_echo -e "changing permission of .additional_system.prop"
        chown 1000 /data/.additional_system.prop
        chgrp 1000 /data/.additional_system.prop
        chmod 644 /data/.additional_system.prop
    fi
}
