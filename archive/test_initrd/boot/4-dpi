VENDOR_PROP_FILE="/data/.vendor.prop"

setup_dpi()
{
	if [ -n "$BST_DPI" ]; then
        VENDOR_OLD_DPI=`grep "ro\.sf\.lcd_density" $VENDOR_PROP_FILE | cut -d '=' -f 2`
        if [ $VENDOR_OLD_DPI -ne $BST_DPI ]; then
            if [ -f $VENDOR_PROP_FILE ]; then
	            sed -i "s/ro.sf.lcd_density=[0-9]*/ro.sf.lcd_density=$BST_DPI/" $VENDOR_PROP_FILE
            fi
        fi
    fi
}
